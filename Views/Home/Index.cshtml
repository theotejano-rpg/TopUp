@{
    ViewData["Title"] = "Dashboard";
    var role = ViewBag.Role as string ?? "Guest";
    var username = ViewBag.Username as string ?? "Guest";
}

<div class="welcome-banner mb-4">
    <div class="welcome-text">
        @if (role == "Admin")
        {
            <span>👑 Welcome back, <strong>Admin</strong>!</span>
        }
        else if (role == "User")
        {
            <span>🎮 Welcome back, <strong>@username</strong>!</span>
        }
        else
        {
            <span>👋 Welcome to <strong>GameTop PH</strong>! <a asp-controller="Account" asp-action="Register" class="text-pink fw-bold">Create an account</a> or <a asp-controller="Account" asp-action="Login" class="text-pink fw-bold">log in</a> to get started.</span>
        }
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-12 col-md-4">
        <div class="stat-card text-center">
            <div class="stat-icon">🎮</div>
            <div class="stat-label">Total Top Ups</div>
            <div class="stat-value text-primary">@ViewBag.TotalTopUps</div>
        </div>
    </div>
    <div class="col-sm-12 col-md-4">
        <div class="stat-card text-center">
            <div class="stat-icon">⏳</div>
            <div class="stat-label">Pending</div>
            <div class="stat-value text-warning">@ViewBag.PendingCount</div>
        </div>
    </div>
    <div class="col-sm-12 col-md-4">
        <div class="stat-card text-center">
            <div class="stat-icon">✅</div>
            <div class="stat-label">Completed</div>
            <div class="stat-value text-success">@ViewBag.CompletedCount</div>
        </div>
    </div>
</div>

@if (role == "Admin")
{
    <div class="row g-4 mb-4">
        <div class="col-sm-12 col-md-6 col-lg-4">
            <div class="stat-card text-center">
                <div class="stat-icon">💰</div>
                <div class="stat-label">Total Revenue</div>
                <div class="stat-value text-success" style="font-size:1.5rem;">
                    ₱@(((decimal)ViewBag.TotalRevenue).ToString("N2"))
                </div>
            </div>
        </div>
    </div>
}

<h6 class="section-heading mb-3">🕹️ Available Games</h6>
<div class="row g-4 mb-2">
    <div class="col-sm-12 col-md-6 col-lg-3">
        <div class="game-card hsr">
            <img src="/images/hsr.png" class="game-img" alt="Honkai: Star Rail" />
            <div class="game-card-name">Honkai: Star Rail</div>
            <div class="game-card-currency">Stellar Jade</div>
            <a asp-controller="TopUp" asp-action="Create" class="btn-game">Top Up Now</a>
        </div>
    </div>
    <div class="col-sm-12 col-md-6 col-lg-3">
        <div class="game-card genshin">
            <img src="/images/genshin.jpg" class="game-img" alt="Genshin Impact" />
            <div class="game-card-name">Genshin Impact</div>
            <div class="game-card-currency">Genesis Crystals</div>
            <a asp-controller="TopUp" asp-action="Create" class="btn-game">Top Up Now</a>
        </div>
    </div>
    <div class="col-sm-12 col-md-6 col-lg-3">
        <div class="game-card wuwa">
            <img src="/images/wuwa.png" class="game-img" alt="Wuthering Waves" />
            <div class="game-card-name">Wuthering Waves</div>
            <div class="game-card-currency">Lunite</div>
            <a asp-controller="TopUp" asp-action="Create" class="btn-game">Top Up Now</a>
        </div>
    </div>
    <div class="col-sm-12 col-md-6 col-lg-3">
        <div class="game-card zzz">
            <img src="/images/zzz.png" class="game-img" alt="Zenless Zone Zero" />
            <div class="game-card-name">Zenless Zone Zero</div>
            <div class="game-card-currency">Polychrome</div>
            <a asp-controller="TopUp" asp-action="Create" class="btn-game">Top Up Now</a>
        </div>
    </div>
</div>