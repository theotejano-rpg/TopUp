@{
    ViewData["Title"] = "Admin Login";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-4">
    <div class="col-sm-12 col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="dash-card-header text-center">🔑 Admin Login</div>
            <div class="card-body p-4">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">❌ @ViewBag.Error</div>
                }

                <p class="text-muted small text-center mb-4">Enter your admin credentials to access the admin panel.</p>

                <form asp-action="Login" method="post">

                    <div class="mb-3">
                        <label class="form-label">👤 Username</label>
                        <input type="text" name="username" class="form-control" placeholder="Enter username" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">🔒 Password</label>
                        <input type="password" name="password" class="form-control" placeholder="Enter password" />
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-pink w-100">🔑 Login</button>
                    </div>

                </form>

                <div class="mt-3 text-center">
                    <small class="text-muted">Default: admin / admin123</small>
                </div>

            </div>
        </div>
    </div>
</div>
